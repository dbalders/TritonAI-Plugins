{
  "name": "@tritonai/plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp check && pnpm validate",
    "compatibility:harness": "node scripts/verify-harness-contract.mjs",
    "package:dry-run": "node scripts/package-dry-run.mjs",
    "readiness": "pnpm check && pnpm typecheck && pnpm test && pnpm package:dry-run",
    "readiness:local": "pnpm readiness && pnpm compatibility:harness",
    "typecheck": "vp run -r typecheck",
    "test": "node --test tests/*.test.mjs && node scripts/test-plugins.mjs",
    "validate": "node scripts/validate-repository.mjs"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "effect": "4.0.0-beta.78",
    "typescript": "~6.0.3",
    "vite-plus": "0.2.1",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@10.24.0"
}
